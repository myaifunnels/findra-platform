# Use sk_test_... while testing and sk_live_... only after go-live approval.
PAYMONGO_SECRET_KEY=sk_test_replace_with_your_paymongo_secret_key
PAYMONGO_ENABLED=true

# Brevo server-to-server email and contacts integration.
BREVO_API_KEY=xkeysib-replace_with_your_brevo_api_key
BREVO_ENABLED=true

# Public origin PayMongo should return customers to after checkout.
PAYMONGO_APP_URL=http://localhost:4173

# Optional production server port.
PORT=4173

# PostgreSQL-backed accounts. Create a Render PostgreSQL database and use its
# Internal Database URL here. Never place this value in frontend code.
DATABASE_URL=postgresql://findra:replace-with-render-internal-url/findra
# Set false only for a local PostgreSQL server without TLS.
DATABASE_SSL=true

# Set this once to the email address of the first Findra administrator. Remove
# it after that administrator is created.
BOOTSTRAP_ADMIN_EMAIL=admin@findra.ph

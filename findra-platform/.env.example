# Use sk_test_... while testing and sk_live_... only after go-live approval.
PAYMONGO_SECRET_KEY=sk_test_replace_with_your_paymongo_secret_key
PAYMONGO_ENABLED=true

# Brevo server-to-server email and contacts integration.
BREVO_API_KEY=xkeysib-replace_with_your_brevo_api_key
BREVO_ENABLED=true

# Public origin PayMongo should return customers to after checkout.
PAYMONGO_APP_URL=http://localhost:4173

# Optional production server port.
PORT=4173
